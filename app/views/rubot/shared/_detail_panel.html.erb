<article class="rubot-panel <%= local_assigns[:panel_class] %>">
  <div class="rubot-page__header">
    <h2><%= title %></h2>
    <% if local_assigns[:badge].present? %>
      <%= badge %>
    <% end %>
  </div>

  <% if local_assigns[:meta].present? %>
    <p class="rubot-card__meta"><%= meta %></p>
  <% end %>

  <% if local_assigns[:badges].present? %>
    <div class="rubot-badge-row"><%= badges %></div>
  <% end %>

  <% if local_assigns[:items].present? && items.any? %>
    <dl class="rubot-kv">
      <% items.each do |item| %>
        <dt><%= item[:label] %></dt>
        <dd><%= item[:value] %></dd>
      <% end %>
    </dl>
  <% end %>

  <% if local_assigns[:body] %>
    <div class="rubot-detail-body"><%= body %></div>
  <% end %>
</article>
