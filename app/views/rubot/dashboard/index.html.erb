<section class="rubot-page">
  <header class="rubot-page__hero">
    <div class="rubot-page__title">
      <p class="rubot-eyebrow">Rubot Admin</p>
      <h1>Dashboard</h1>
      <p class="rubot-page__lede">A console-first overview of workflow traffic, approval pressure, tool reliability, and model spend across the current workspace.</p>
      <div class="rubot-page__meta">
        <span class="rubot-page__meta-chip">Runs and approvals</span>
        <span class="rubot-page__meta-chip">Trace-first debugging</span>
        <span class="rubot-page__meta-chip">Render-inspired dark console</span>
      </div>
    </div>
  </header>

  <section class="rubot-stats-grid">
    <%= rubot_stat label: "Total Runs", value: @dashboard[:summary][:total_runs], tone: "neutral" %>
    <%= rubot_stat label: "Active Runs", value: @dashboard[:summary][:active_runs], tone: "info" %>
    <%= rubot_stat label: "Pending Approvals", value: @dashboard[:summary][:pending_approvals], tone: "warning" %>
    <%= rubot_stat label: "Failed Runs", value: @dashboard[:summary][:failed_runs], tone: "danger" %>
    <%= rubot_stat label: "Tool Success", value: (@dashboard[:summary][:tool_success_rate] ? "#{(@dashboard[:summary][:tool_success_rate] * 100).round}%": "n/a"), tone: "info" %>
    <%= rubot_stat label: "Model Tokens", value: @dashboard[:summary][:total_model_tokens], tone: "neutral" %>
  </section>

  <article class="rubot-panel">
    <div class="rubot-page__header">
      <h2>Platform Metrics</h2>
    </div>
    <div class="rubot-page__meta">
      <span class="rubot-page__meta-chip">Average duration: <%= @dashboard[:summary][:average_duration_seconds] || "n/a" %>s</span>
      <span class="rubot-page__meta-chip">Approval wait: <%= @dashboard[:summary][:average_approval_wait_seconds] || "n/a" %>s</span>
      <span class="rubot-page__meta-chip">Estimated model cost: $<%= format("%.6f", @dashboard[:summary][:total_model_cost]) %></span>
    </div>
  </article>

  <article class="rubot-panel">
    <div class="rubot-page__header">
      <h2>Recent Runs</h2>
      <%= link_to "View all runs", rubot.runs_path, class: "rubot-link" %>
    </div>

    <% if @dashboard[:recent_runs].any? %>
      <div class="rubot-card-list">
        <% @dashboard[:recent_runs].each do |run| %>
          <section class="rubot-card">
            <div class="rubot-card__header">
              <div>
                <h3><%= link_to run.name, rubot.run_path(run.id), class: "rubot-link" %></h3>
                <p class="rubot-card__meta"><%= run.current_step %> · <%= run.duration %></p>
              </div>
              <%= rubot_status_badge(run.run.status) %>
            </div>
          </section>
        <% end %>
      </div>
    <% else %>
      <%= render "rubot/runs/empty_state", title: "No runs yet", body: "The admin shell is wired up. Runs will appear here as workflows and agents execute." %>
    <% end %>
  </article>
</section>
