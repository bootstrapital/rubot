<div id="<%= Rubot::LiveUpdates.run_overview_dom_id(run.id) %>">
  <article class="rubot-panel">
    <div class="rubot-page__header">
      <h2>Overview</h2>
      <%= rubot_status_badge(run.run.status) %>
    </div>

    <dl class="rubot-kv">
      <dt>Started</dt>
      <dd><%= run.started_at %></dd>
      <dt>Completed</dt>
      <dd><%= run.completed_at %></dd>
    </dl>

    <div class="rubot-step-synopsis">
      <h3>Workflow steps</h3>

      <% if run.step_groups.any? %>
        <ol class="rubot-step-synopsis__list">
          <% run.step_groups.each do |step| %>
            <li class="rubot-step-synopsis__item">
              <div class="rubot-step-synopsis__header">
                <strong>
                  <%= link_to step[:name],
                              rubot.run_path(run.id, tab: "execution", anchor: rubot_step_anchor(step[:name])),
                              class: "rubot-link" %>
                </strong>
                <%= rubot_status_badge(step[:status]) %>
              </div>
              <p class="rubot-card__meta"><%= rubot_payload_summary(step[:result]) %></p>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="rubot-card__meta">No step activity recorded yet.</p>
      <% end %>
    </div>
  </article>
</div>
