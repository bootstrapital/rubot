<div id="<%= Rubot::LiveUpdates.run_overview_dom_id(run.id) %>">
  <%= render "rubot/shared/detail_panel",
             title: "Overview",
             badge: rubot_status_badge(run.run.status),
             items: [
               { label: "Current step", value: run.current_step },
               { label: "Started", value: run.started_at },
               { label: "Completed", value: run.completed_at }
             ] %>
</div>
