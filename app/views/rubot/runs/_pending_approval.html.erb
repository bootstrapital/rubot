<div id="<%= Rubot::LiveUpdates.run_pending_approval_dom_id(run.id) %>">
  <% if run.run.waiting_for_approval? %>
    <% approval_form = capture do %>
      <%= rubot_schema_form(
                 title: "Approval payload",
                 meta: "Schema-driven form block",
                 schema: Rubot::Schema.build { string :approved_by; string :note, required: false },
                 url: rubot.approve_approval_path(run.id),
                 method: :patch,
                 values: { approved_by: "operator" },
                 submit_label: "Approve") %>
    <% end %>

    <%= rubot_action_panel(
               title: "Pending approval",
               description: "This action block can approve or reject the current workflow gate.",
               content: approval_form) %>
    <div class="rubot-actions">
      <%= button_to "Reject", rubot.reject_approval_path(run.id), method: :patch, params: { approved_by: "operator" }, class: "rubot-button rubot-button--secondary" %>
    </div>
  <% end %>
</div>
