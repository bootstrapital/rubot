<div id="<%= Rubot::LiveUpdates.runs_table_dom_id %>">
  <% if runs.any? %>
    <table class="rubot-table">
      <thead>
        <tr>
          <th>Run</th>
          <th>Status</th>
          <th>Step</th>
          <th>Started</th>
          <th>Duration</th>
        </tr>
      </thead>
      <%= render "table_body", runs: runs %>
    </table>
  <% else %>
    <%= render "empty_state", title: "No runs yet", body: "Start a workflow or agent run and it will show up here with realtime status updates." %>
  <% end %>
</div>
