<section class="rubot-page">
  <header class="rubot-page__header">
    <div>
      <p class="rubot-eyebrow">Tool Call</p>
      <h1><%= @tool_call.short_name %></h1>
    </div>
    <div class="rubot-actions">
      <%= link_to "Back to Run", rubot.run_path(@run.id), class: "rubot-link" %>
      <%= link_to "Approval Inbox", rubot.approvals_path, class: "rubot-link" %>
    </div>
  </header>

  <section class="rubot-workbench">
    <div class="rubot-workbench__main">
      <% tool_overview_badges = capture do %>
        <%= rubot_confidence_badge(@tool_call.confidence) %>
        <%= rubot_warning_badges(@tool_call.warnings) %>
      <% end %>

      <%= rubot_detail_panel(
                 title: "Tool Overview",
                 badge: rubot_status_badge(@tool_call.status),
                 badges: tool_overview_badges) %>
      <%= rubot_schema_result(
                 title: "Input",
                 meta: "Schema-driven result block",
                 schema: @tool_call.input_schema,
                 payload: @tool_call.input) %>
      <%= rubot_schema_result(
                 title: "Output",
                 meta: "Schema-driven result block",
                 schema: @tool_call.output_schema,
                 payload: @tool_call.output) %>
      <%= rubot_diff_block(
                 title: "Input / Output Diff",
                 meta: "Reusable diff block",
                 before_value: @tool_call.input,
                 after_value: @tool_call.output) %>
    </div>

    <aside class="rubot-workbench__side">
      <%= rubot_detail_panel(
                 title: "Execution",
                 items: [
                   { label: "Step", value: @tool_call.step_name || "unscoped" },
                   { label: "Duration", value: (@tool_call.duration_ms ? "#{@tool_call.duration_ms}ms" : "n/a") }
                 ]) %>
      <%= rubot_action_panel(
                 title: "Actions",
                 description: "Reusable action panel block for operator workflows.",
                 actions: [
                   link_to("Back to Run", rubot.run_path(@run.id), class: "rubot-button rubot-button--secondary"),
                   link_to("Approval Inbox", rubot.approvals_path, class: "rubot-button")
                 ]) %>
    </aside>
  </section>

  <% if @tool_call.error %>
    <article class="rubot-panel rubot-panel--danger">
      <h2>Error</h2>
      <pre><%= rubot_json(@tool_call.error) %></pre>
    </article>
  <% end %>
</section>
