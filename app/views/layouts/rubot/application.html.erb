<!DOCTYPE html>
<html>
  <head>
    <title>Rubot Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "rubot/application", media: "all" %>
  </head>
  <body class="rubot-shell">
    <aside class="rubot-shell__sidebar">
      <div class="rubot-shell__brand">
        <p class="rubot-shell__eyebrow">Rubot</p>
        <h1>Admin</h1>
        <p class="rubot-shell__caption">Runs, approvals, replay, traces, and developer diagnostics.</p>
      </div>

      <nav class="rubot-shell__nav">
        <% rubot_navigation.each do |item| %>
          <%= rubot_nav_link(item, current_path: request.path) %>
        <% end %>
      </nav>
    </aside>

    <main class="rubot-shell__main">
      <header class="rubot-topbar">
        <div class="rubot-topbar__crumbs">
          <% rubot_breadcrumbs.each_with_index do |crumb, index| %>
            <% if crumb[:path].present? && index < rubot_breadcrumbs.length - 1 %>
              <%= link_to crumb[:label], crumb[:path] %>
            <% else %>
              <strong><%= crumb[:label] %></strong>
            <% end %>

            <% unless index == rubot_breadcrumbs.length - 1 %>
              <span>/</span>
            <% end %>
          <% end %>
        </div>
      </header>

      <%= yield %>
    </main>
  </body>
</html>
